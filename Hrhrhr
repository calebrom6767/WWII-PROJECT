    .cite-card p {
      font-size: 0.88em;
      line-height: 1.5;
      color: var(--faded);
      margin-bottom: 6px;
    }
    .cite-card a {
      font-size: 0.78em;
      color: var(--khaki);
      word-break: break-all;
      text-decoration: underline dotted;
      display: block;
    }
    .cite-card a:hover { color: var(--cream); }
    .stamp {
      display: inline-block;
      border: 3px solid var(--rust);
      padding: 6px 14px;
      font-family: 'Special Elite', cursive;
      font-size: 0.7em;
      letter-spacing: 3px;
