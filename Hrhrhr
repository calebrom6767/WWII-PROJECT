  <style>
    :root {
      --olive: #4a4a2a;
      --khaki: #8b7d5a;
      --cream: #f5f0e0;
      --dark: #1e1c14;
      --rust: #8b3a1a;
      --faded: #c9b99a;
      --paper: #ede8d5;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background-color: var(--dark);
      background-image:
        repeating-linear-gradient(0deg, transparent, transparent 40px, rgba(255,255,255,0.015) 40px, rgba(255,255,255,0.015) 41px),
        radial-gradient(ellipse at top left, #2a2810 0%, #1e1c14 60%);
      color: var(--cream);
      font-family: 'Libre Baskerville', serif;
      min-height: 100vh;
      padding: 0 0 80px 0;
    }
    .hero {
      background: linear-gradient(to bottom, #0a0a06 0%, #1e1c14 100%);
      border-bottom: 4px solid var(--khaki);
      padding: 60px 24px 50px;
      text-align: center;
    }
    .hero::before {
      content: "✦ 1939 – 1945 ✦";
      display: block;
      font-family: 'Special Elite', cursive;
      font-size: 0.85em;
      letter-spacing: 6px;
      color: var(--khaki);
      margin-bottom: 18px;
    }
    .hero h1 {
      font-family: 'Special Elite', cursive;
      font-size: clamp(1.8em, 5vw, 3.2em);
      color: var(--cream);
      letter-spacing: 2px;
      line-height: 1.2;
      text-shadow: 3px 3px 12px rgba(0,0,0,0.8);
      margin-bottom: 20px;
    }
    .hero h1 span {
      color: var(--faded);
      font-size: 0.55em;
      display: block;
      letter-spacing: 4px;
      margin-bottom: 8px;
    }
    .inquiry-box {
      max-width: 720px;
      margin: 28px auto 0;
      border: 2px solid var(--khaki);
      background: rgba(74,74,42,0.2);
      padding: 22px 28px;
      position: relative;
    }
    .inquiry-box::before {
      content: "APPROVED INQUIRY QUESTION";
      position: absolute;
      top: -11px;
      left: 50%;
      transform: translateX(-50%);
      background: #0a0a06;
      padding: 0 12px;
      font-family: 'Special Elite', cursive;
      font-size: 0.7em;
      letter-spacing: 3px;
      color: var(--khaki);
      white-space: nowrap;
    }
    .inquiry-box p {
      font-style: italic;
      font-size: 1.05em;
      color: var(--cream);
      line-height: 1.7;
    }
    .container {
      max-width: 900px;
      margin: 0 auto;
      padding: 0 24px;
    }
    .exhibit { margin-top: 60px; }
    .exhibit-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 28px;
    }
    .exhibit-tag {
      background: var(--rust);
      font-family: 'Special Elite', cursive;
      font-size: 0.75em;
      letter-spacing: 3px;
      padding: 6px 14px;
      color: var(--cream);
      white-space: nowrap;
      flex-shrink: 0;
    }
    .exhibit-line {
      flex: 1;
      height: 2px;
      background: linear-gradient(to right, var(--rust), transparent);
    }
    .exhibit-title {
      font-family: 'Special Elite', cursive;
      font-size: 1.5em;
      color: var(--faded);
      letter-spacing: 1px;
      margin-bottom: 6px;
    }
    .paper-card {
      background: var(--paper);
      color: var(--dark);
      border-left: 5px solid var(--khaki);
      padding: 28px 32px;
      margin-bottom: 28px;
      position: relative;
      box-shadow: 4px 4px 20px rgba(0,0,0,0.5);
    }
    .paper-card::after {
      content: "";
      position: absolute;
      top: 0; right: 0;
      width: 0; height: 0;
      border-style: solid;
      border-width: 0 28px 28px 0;
      border-color: transparent var(--dark) transparent transparent;
    }
    .card-label {
      font-family: 'Special Elite', cursive;
      font-size: 0.75em;
      letter-spacing: 3px;
      color: var(--rust);
      margin-bottom: 14px;
      text-transform: uppercase;
    }
    .card-title {
      font-family: 'Special Elite', cursive;
      font-size: 1.2em;
      color: var(--olive);
      margin-bottom: 14px;
      border-bottom: 1px dashed var(--khaki);
      padding-bottom: 10px;
    }
    .paper-card ul { padding-left: 20px; list-style: none; }
    .paper-card ul li {
      position: relative;
      padding-left: 18px;
      margin-bottom: 10px;
      font-size: 0.97em;
      line-height: 1.65;
      color: #2a2010;
    }
    .paper-card ul li::before {
      content: "▸";
      position: absolute;
      left: 0;
      color: var(--rust);
      font-size: 0.85em;
      top: 2px;
    }
    .source-footer {
      margin-top: 18px;
      padding-top: 12px;
      border-top: 1px dashed #b0a080;
      font-size: 0.82em;
      color: #5a4a30;
    }
    .source-footer strong {
      font-family: 'Special Elite', cursive;
      color: var(--rust);
      letter-spacing: 1px;
    }
    .source-footer a {
      color: var(--olive);
      word-break: break-all;
      text-decoration: underline dotted;
      display: block;
      margin-top: 3px;
    }
    .source-footer a:hover { color: var(--rust); }
    .cite-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
      gap: 16px;
    }
    .cite-card {
      background: rgba(74,74,42,0.15);
      border: 1px solid var(--khaki);
      padding: 16px 18px;
    }
    .cite-num {
      font-family: 'Special Elite', cursive;
      font-size: 0.7em;
      letter-spacing: 2px;
      color: var(--khaki);
      margin-bottom: 6px;
